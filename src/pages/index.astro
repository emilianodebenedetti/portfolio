---
import Layout from '../layouts/Layout.astro';
/* import Badge from '../components/Badge.astro' */
import IconsList from '../components/IconsList.astro';
/* import LinkedinIcon from '../components/icons/LinkedinIcon.astro'; */
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import MailIcon from '../components/icons/MailIcon.astro';
import Experience from '../components/Experience.astro';
import SectionContainer from '../components/SectionContainer.astro';
import BooksIcon from '../components/icons/BooksIcon.astro'; 
import Code from '../components/icons/CodeIcon.astro';
import Projects from '../components/Projects.astro'
import Footer from '../components/Footer.astro'
import ButtonCV from '../components/ButtonCV.astro'
---

<Layout 
	title="Emiliano Debenedetti - Desarrollador Full Stack."
	description="Desarrollador Full Stack."
	>
	<main class="px-4">
		<!-- Sobre mi -->
		<SectionContainer id="sobre-mi" class="py-20 lg:py-44">
			<img
				class="rounded-full size-32 lg:size-48 object-cover"
				src="/perfil/foto-yo.jpg"
				alt="Profile Photo"
			/>
			<h1 class="text-white text-3xl md:text-4xl lg:text-5xl font-bold flex flex-row gap-x-4 py-4 lg:py-10">
				Hola, por aquí Emiliano 👋
			</h1>
			<h2 class="text-md md:text-2xl text-wrap max-w-[700px] text-white/70">
				<span class="text-teal-400">Estudiante de programación desde 2022.</span>
				Actualmente cursando <span class="text-white">"Licenciatura en Tecnologías de la Información" (Plan 2024)</span> en  
				<span class="text-blue-600">UTEC.</span> y trabajando como <span class="text-white">Analista en Infraestructura TI Jr.</span> en <span class="text-blue-600">Rockshore Inversores.</span>
			</h2>
			<!-- quiero agregar aqui abajo un pin con la informacion de donde vivo -->
			<div class="flex items-center gap-2 mt-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-400" viewBox="0 0 20 20" fill="currentColor">
					<path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
				</svg>
				<p class="text-white/70">Montevideo, Uruguay</p>
			</div>
			<nav class="flex gap-2 lg:gap-x-6 mt-8 flex-wrap bg-inherit text-white/80 dark:text-white/80">
				<IconsList href="https://github.com/emilianodebenedetti">
					<GitHubIcon class="size-6"/>
					GitHub
				</IconsList>
				<IconsList href="mailto:emiliano_debenedetti@outlook.com">
					<MailIcon class="size-6"/>
					emiliano_debenedetti@outlook.com
				</IconsList>
			</nav>		
		</SectionContainer>

		<!-- Educación y Experiencia Laboral -->
		<SectionContainer id="educacion-y-experiencia">
			<h2 class="text-2xl lg:text-3xl font-semibold mb-6 flex gap-x-2 items-center">
				<BooksIcon class="size-7 text-teal-400" />
				Educación y Experiencia Laboral
			</h2>
			<Experience/>
			<ButtonCV/>
		</SectionContainer>
		
		<!-- Proyectos -->
		<SectionContainer id="proyectos">
			<h2 class="text-2xl md:text-3xl font-semibold mb-6 flex gap-x-2 items-center">
				<Code class="size-7 text-teal-400/80" />
				Proyectos
			</h2>
			<Projects/>
		</SectionContainer>

		<Footer id="#contacto" />

	</main>
</Layout>